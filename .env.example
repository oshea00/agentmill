# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Anthropic API key — used by MessagesAPIRunner and ClaudeCodeRunner
ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# IRC gateway (server managed externally)
# ---------------------------------------------------------------------------

# host.docker.internal resolves to the Docker host on Linux and macOS.
# Replace with the actual IP/hostname of your IRC server if running elsewhere.
IRC_HOST=host.docker.internal
IRC_PORT=6667
IRC_NICK=orchestrator
IRC_CHANNEL=#agents

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

LOG_LEVEL=INFO

# Optional: send OTel spans to a remote collector (e.g. Jaeger, Honeycomb)
# Leave blank to write traces to /data/traces/ only.
OTLP_ENDPOINT=

# ---------------------------------------------------------------------------
# MCP server credentials (only needed if you reference them in mcp_servers.json)
# ---------------------------------------------------------------------------

BRAVE_API_KEY=
DATABASE_URL=
